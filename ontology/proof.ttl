@prefix ckp:  <https://conceptkernel.org/ontology/v3.8/core#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<https://conceptkernel.org/ontology/v3.8/proof> a owl:Ontology ;
  rdfs:comment "Manual split module for proof semantics. ckp.boot() does not load this file yet; ontology/core.ttl remains runtime-authoritative." .

ckp:Proof a rdfs:Class ;
  rdfs:comment "Durable attestation that a governed write or verification result can be checked later." .

ckp:validation a owl:ObjectProperty ;
  rdfs:comment "Links a Proof object to the Validation object that justified it." .

ckp:delivery a owl:ObjectProperty ;
  rdfs:comment "Links a Proof object to the Delivery object that bounded acceptance." .

ckp:delegation a owl:ObjectProperty ;
  rdfs:comment "Links a Proof object to the Delegation object that carried verified caller context." .
