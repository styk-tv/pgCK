@prefix ckp:  <https://conceptkernel.org/ontology/v3.8/core#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<https://conceptkernel.org/ontology/v3.8/goal> a owl:Ontology ;
  rdfs:comment "Manual split module for goal semantics. ckp.boot() does not load this file yet; ontology/core.ttl remains runtime-authoritative." .

ckp:Goal a rdfs:Class ;
  rdfs:comment "URI-native objective or governed intent object." .
