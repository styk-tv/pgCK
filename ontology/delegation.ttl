@prefix ckp:  <https://conceptkernel.org/ontology/v3.8/core#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<https://conceptkernel.org/ontology/v3.8/delegation> a owl:Ontology ;
  rdfs:comment "Manual split module for delegation semantics. ckp.boot() does not load this file yet; ontology/core.ttl remains runtime-authoritative." .

ckp:Delegation a rdfs:Class ;
  rdfs:comment "Delegation, proof-of-possession, or identity-bearing caller-context object." .

ckp:delegation a owl:ObjectProperty ;
  rdfs:comment "Links a Delivery, Validation, or Proof object to the Delegation object that bound caller identity context." .
