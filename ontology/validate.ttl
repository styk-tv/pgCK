@prefix ckp:  <https://conceptkernel.org/ontology/v3.8/core#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<https://conceptkernel.org/ontology/v3.8/validate> a owl:Ontology ;
  rdfs:comment "Manual split module for validation semantics. ckp.boot() does not load this file yet; ontology/core.ttl remains runtime-authoritative." .

ckp:Validation a rdfs:Class ;
  rdfs:comment "First-class SHACL validation report or validation result object." .
