@prefix ckp:  <https://conceptkernel.org/ontology/v3.7/> .
@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix :     <urn:ckp:board#> .

:GoalTaskBoard a ckp:Kernel ;
  rdfs:label "Goal Task Board" ;
  ckp:launch_url "https://board.localhost" .

ckp:GoalShape a sh:NodeShape ;
  sh:targetClass ckp:Goal ;
  sh:property [ sh:path ckp:goal_id ; sh:minCount 1 ; sh:datatype xsd:string ] ;
  sh:property [ sh:path ckp:title ; sh:minCount 1 ; sh:datatype xsd:string ] ;
  sh:property [ sh:path ckp:created_at ; sh:minCount 1 ; sh:datatype xsd:string ] ;
  sh:property [ sh:path ckp:created_by ; sh:datatype xsd:string ] ;
  sh:property [ sh:path ckp:detail ; sh:datatype xsd:string ] .

ckp:TaskShape a sh:NodeShape ;
  sh:targetClass ckp:Task ;
  sh:property [ sh:path ckp:task_id ; sh:minCount 1 ; sh:datatype xsd:string ] ;
  sh:property [ sh:path ckp:title ; sh:minCount 1 ; sh:datatype xsd:string ] ;
  sh:property [ sh:path ckp:part_of_goal ; sh:minCount 1 ; sh:datatype xsd:string ] ;
  sh:property [ sh:path ckp:target_kernel ; sh:minCount 1 ; sh:datatype xsd:string ] ;
  sh:property [ sh:path ckp:lifecycle_state ; sh:minCount 1 ; sh:datatype xsd:string ] ;
  sh:property [ sh:path ckp:priority ; sh:minCount 1 ; sh:datatype xsd:integer ] ;
  sh:property [ sh:path ckp:queue_seq ; sh:minCount 1 ; sh:datatype xsd:integer ] ;
  sh:property [ sh:path ckp:created_at ; sh:minCount 1 ; sh:datatype xsd:string ] ;
  sh:property [ sh:path ckp:created_by ; sh:datatype xsd:string ] ;
  sh:property [ sh:path ckp:detail ; sh:datatype xsd:string ] .
