# pgCK — PostgreSQL Concept Kernel extension (rc3)
comment = 'Concept Kernel Protocol runtime in-database: NATS bridge + SHACL validator + materializer'
default_version = '0.1.0'
module_pathname = '$libdir/pgck'
relocatable = false
# pgRDF must be installed in the same DB (compose bind-mounts it).
requires = 'pgrdf'
superuser = true
